generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {

  id            String   @id @default(uuid())

  firstName     String

  lastName      String

  username      String   @unique

  email         String   @unique

  passwordHash  String

  phoneNumber   String?

  role          String   @default("USER")

  createdAt     DateTime @default(now())

  refreshTokens RefreshToken[]
}

model RefreshToken {

  id         String   @id @default(uuid())

  token      String

  userId     String

  expiresAt  DateTime

  revokedAt  DateTime?

  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}